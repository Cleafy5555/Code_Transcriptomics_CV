# ============================================================================
# Chapter 3 | Publication-style host PCA plots
# ============================================================================
# Purpose:
# - Rebuild cleaner PCA plots from the VST matrices produced by Script 01.
# - Export one PCA per genotype plus a combined PCA across all genotypes.
# - Apply the final chapter colour and shape scheme for publication figures.
#
# Main inputs:
# - outputs/intermediate/host_deseq_within_genotype/chosen_analysis/
# - sample_metadata.csv
# - genotype-specific *_vst_counts.csv files
#
# Main outputs:
# - cleaned PCA plots and PCA coordinate tables for the host analyses.
#
# Notes:
# - This script is presentation-focused: it does not rerun DESeq2.
# - It assumes Script 01 has already created the VST matrices and metadata.
#
# Repository note:
# - This repository contains cleaned analysis code only.
# - Raw sequencing/count files and large external annotation resources are not included.
# - Scripts generally assume earlier steps have already produced the intermediate files they read.
# {'='*76}


suppressPackageStartupMessages({
  library(DESeq2)
  library(readr)
  library(dplyr)
  library(ggplot2)
  library(tibble)
})

base_dir <- file.path("outputs", "intermediate", "host_deseq_within_genotype", "chosen_analysis")
fig_dir  <- file.path("outputs", "figures")
stat_dir <- file.path("outputs", "stats")
dir.create(fig_dir, recursive = TRUE, showWarnings = FALSE)
dir.create(stat_dir, recursive = TRUE, showWarnings = FALSE)

genotypes <- c("Broccolini", "Broccoli", "GaiLan")
meta_file   <- file.path(base_dir, "sample_metadata.csv")
counts_file <- file.path(base_dir, "counts_matrix_merged.csv")
stopifnot(file.exists(meta_file), file.exists(counts_file))

meta <- read_csv(meta_file, show_col_types = FALSE) %>%
  mutate(genotype = factor(genotype, levels = c("Broccolini", "Broccoli", "GaiLan")),
         stage = factor(stage, levels = c("Control", "Spore_adhesion", "ESP", "MSP")))

stage_cols <- c("Control" = "grey", "Spore adhesion" = "#FBACBE", "ESP" = "#B9D2B1", "MSP" = "#A18276")
genotype_cols <- c("Broccolini" = "#2A9134", "Broccoli" = "#F96900", "GaiLan" = "#28AFB0")
stage_shapes <- c("Control" = 16, "Spore adhesion" = 17, "ESP" = 15, "MSP" = 18)

make_pca_plot <- function(geno_name, base_dir, meta) {
  vst_file <- file.path(base_dir, geno_name, paste0(geno_name, "_vst_counts.csv"))
  stopifnot(file.exists(vst_file))
  vst_df <- read_csv(vst_file, show_col_types = FALSE)
  meta_g <- meta %>% filter(genotype == geno_name)
  vst_mat <- vst_df %>% column_to_rownames("gene") %>% as.matrix()
  common_samples <- intersect(meta_g$sample, colnames(vst_mat))
  meta_g <- meta_g %>% filter(sample %in% common_samples)
  vst_mat <- vst_mat[, meta_g$sample, drop = FALSE]
  pca <- prcomp(t(vst_mat), center = TRUE, scale. = FALSE)
  percentVar <- (pca$sdev^2 / sum(pca$sdev^2)) * 100
  pca_df <- as.data.frame(pca$x[, 1:2]) %>%
    rownames_to_column("sample") %>%
    left_join(meta_g, by = "sample") %>%
    mutate(stage = factor(stage,
                          levels = c("Control", "Spore_adhesion", "ESP", "MSP"),
                          labels = c("Control", "Spore adhesion", "ESP", "MSP")))
  p <- ggplot(pca_df, aes(x = PC1, y = PC2, color = stage)) +
    geom_point(size = 4) +
    labs(title = paste("PCA -", geno_name),
         x = paste0("PC1: ", round(percentVar[1]), "% variance"),
         y = paste0("PC2: ", round(percentVar[2]), "% variance"),
         color = "Stage") +
    scale_color_manual(values = stage_cols) +
    theme_classic(base_size = 18)
  ggsave(file.path(fig_dir, paste0("02_", geno_name, "_PCA_clean.png")), p, width = 7, height = 5, dpi = 300)
  write_csv(pca_df, file.path(stat_dir, paste0("02_", geno_name, "_PCA_clean_data.csv")))
  p
}

plots <- lapply(genotypes, make_pca_plot, base_dir = base_dir, meta = meta)
names(plots) <- genotypes

counts_df <- read_csv(counts_file, show_col_types = FALSE)
counts_mat <- counts_df %>% distinct(gene, .keep_all = TRUE) %>% column_to_rownames("gene") %>% as.matrix()
mode(counts_mat) <- "integer"
counts_mat <- counts_mat[, meta$sample, drop = FALSE]

dds_all <- DESeqDataSetFromMatrix(countData = counts_mat, colData = as.data.frame(meta), design = ~ genotype + stage)
keep <- rowSums(counts(dds_all) >= 10) >= 3
dds_all <- dds_all[keep, ]
vsd_all <- vst(dds_all, blind = TRUE)

pca <- prcomp(t(assay(vsd_all)), center = TRUE, scale. = FALSE)
percentVar <- (pca$sdev^2 / sum(pca$sdev^2)) * 100
pca_df <- as.data.frame(pca$x[, 1:2]) %>%
  rownames_to_column("sample") %>%
  left_join(meta, by = "sample") %>%
  mutate(stage = factor(stage,
                        levels = c("Control", "Spore_adhesion", "ESP", "MSP"),
                        labels = c("Control", "Spore adhesion", "ESP", "MSP")))

p_combined <- ggplot(pca_df, aes(x = PC1, y = PC2, color = genotype, shape = stage)) +
  geom_point(size = 4, stroke = 1) +
  labs(title = "PCA - all genotypes",
       x = paste0("PC1: ", round(percentVar[1]), "% variance"),
       y = paste0("PC2: ", round(percentVar[2]), "% variance"),
       color = "Genotype", shape = "Stage") +
  scale_color_manual(values = genotype_cols) +
  scale_shape_manual(values = stage_shapes) +
  theme_classic(base_size = 18)

ggsave(file.path(fig_dir, "02_PCA_all_genotypes_clean.png"), p_combined, width = 8, height = 6, dpi = 300)
write_csv(pca_df, file.path(stat_dir, "02_PCA_all_genotypes_clean_data.csv"))
